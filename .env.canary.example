# Canary 1B V2 service configuration

# Inference
MODEL_PRECISION=fp16
DEVICE=cuda
BATCH_SIZE=1
MAX_AUDIO_DURATION=60

# Streaming — how often to run transcription on the growing buffer
TRANSCRIBE_INTERVAL_S=1.0
# Silence timeout — seconds of no audio before emitting final result
SILENCE_TIMEOUT_S=1.5

# Server
PROCESSING_TIMEOUT=120
LOG_LEVEL=INFO
