# Development Dockerfile for dstack dev environments
# Based on CUDA 12.1 with cuDNN 8 - stable and proven with NeMo/Parakeet TDT
# Using devel variant for development tools
FROM --platform=linux/amd64 nvidia/cuda:12.1.0-cudnn8-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PIP_BREAK_SYSTEM_PACKAGES=1

# Install Python 3.10 and development tools (Python 3.10 is default on Ubuntu 22.04)
RUN apt-get update && apt-get install -y \
    python3.10 \
    python3.10-dev \
    python3.10-venv \
    python3-pip \
    build-essential \
    git \
    curl \
    wget \
    vim \
    htop \
    screen \
    tmux \
    && rm -rf /var/lib/apt/lists/*

# Set Python 3.10 as default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1 \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1

WORKDIR /workspace

# Install UV by copying from official distroless image (recommended by UV docs)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Copy project files
COPY pyproject.toml .
COPY README.md .

# Install dependencies with UV using cache mount (improves build performance)
# Use --no-install-project since code will be mounted from local via repos
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --no-install-project --all-extras

# Verify dependencies are installed (not the project itself)
RUN uv run python -c 'import torch; print("PyTorch:", torch.__version__, "CUDA:", torch.version.cuda)' && \
    uv run python -c 'import nemo; print("NeMo:", nemo.__version__)'

# Expose port for server
EXPOSE 8000

# Default command (can be overridden)
CMD ["bash"]
